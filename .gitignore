# Secrets and environment
.env
.env.*
!.env.example
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# State — event log is regenerable from renders + cost reports; manifest is tracked
state/events.db
state/events.db-journal
state/events.db-wal
state/events.db-shm

# Generated artifacts — large binaries; tracked loglines, not media
artifacts/renders/**/*.mp4
artifacts/renders/**/*.mov
artifacts/renders/**/*.webm
artifacts/audio/**/*.wav
artifacts/audio/**/*.mp3
artifacts/audio/**/*.m4a
artifacts/edit/*.mp4
artifacts/edit/*.mov
artifacts/storybook/**/*.mp4
artifacts/storybook/**/*.png
artifacts/dragon_tortoise/**/*.mp4
artifacts/dragon_tortoise/**/*.png
site/media/shots/**/*.mp4
site/media/shots/**/*.png

# Demo fixtures — large; stored elsewhere (see demo/README.md when created)
demo/fixtures/**/*.mp4
demo/fixtures/**/*.wav
demo/fixtures/**/*.mp3

# Keep FCPXML text artifacts tracked for inspectability
!artifacts/edit/*.fcpxml

# IDE / OS
.DS_Store
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*~

# Logs
*.log
logs/

# scratch/ — probe evidence is tracked; regenerable scaffolding + heavy artifacts are not.
# Tracked: PROBE_REPORT.md, probe scripts, transcripts (the evidence that justified the pivot).
# Ignored: hyperframes init scaffolding (recreatable via `npx hyperframes init`), rendered MP4s,
# per-agent-harness skill symlinks (the skills installer fans out to ~30 dot-dirs), npm caches,
# the local probe events.db.
scratch/*/node_modules/
scratch/*/.*
scratch/*/skills/
scratch/*/skills-lock.json
scratch/*/*.mp4
scratch/*.db
scratch/hyperframes-probe/AGENTS.md
scratch/hyperframes-probe/CLAUDE.md
scratch/hyperframes-probe/hyperframes.json
scratch/hyperframes-probe/index.html
scratch/hyperframes-probe/meta.json
