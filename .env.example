# Copy to .env and fill in. .env is gitignored.

# --- Anthropic (Opus 4.7 orchestration, Managed Agents) ---
ANTHROPIC_API_KEY=

# --- fal.ai (Kling 2.x; future Runway/LTX) ---
# Two keys for failover and rate-limit resilience. $68 credit each.
# Renderer rotates: FAL_KEY_PRIMARY first; on auth/quota error, falls over to FAL_KEY_SECONDARY.
FAL_KEY_PRIMARY=
FAL_KEY_SECONDARY=

# --- Alibaba Cloud (Wan 2.7 Plus/Turbo) ---
# DashScope API. Free quota, expires 2026-07-19.
DASHSCOPE_API_KEY=

# --- Google Cloud Vertex AI (Veo 3.1 Fast — hero shots only, $15 cap) ---
# Auth: Application Default Credentials (ADC), NOT a service-account key file.
# Org policy iam.managed.disableServiceAccountKeyCreation blocks SA keys on this
# project; ADC is the sanctioned (and more secure) path.
#
# One-time setup:
#   gcloud auth login
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project <GCP_PROJECT_ID>   # required!
#   gcloud services enable aiplatform.googleapis.com --project=<GCP_PROJECT_ID>
#   gcloud projects add-iam-policy-binding <GCP_PROJECT_ID> \
#       --member="user:<your-gcp-email>" --role="roles/aiplatform.user"
#
# Verify with:  bash scripts/verify_vertex.sh
#
# Leave GOOGLE_APPLICATION_CREDENTIALS blank — ADC is auto-discovered from
# ~/.config/gcloud/application_default_credentials.json.
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
VEO_MODEL_ID=veo-3.1-fast-generate-001

# --- ElevenLabs (all audio) ---
ELEVENLABS_API_KEY=

# --- Pipeline flags ---
# DEMO_MODE=1 swaps provider adapters to read from demo/fixtures/ instead of live APIs.
DEMO_MODE=0
